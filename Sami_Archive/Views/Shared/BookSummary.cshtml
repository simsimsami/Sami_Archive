@model Book

<div class="card card-outline-primary m-1 p-1">
    <div class="bg-faded p-1">
        <h4>
            @Model?.Title
        </h4>
    </div>
    <div class="card-text p-1">@Model?.Genre</div>
    <div class="card-text p-1">@Model?.Description</div>

    <form id="@Model?.BookID" asp-controller="Book" asp-route-id="@Model?.BookID" asp-action="Edit">
        <button type="submit"
                class="btn btn-success btn-sm pull-right" style="float:right">
            Edit Book
        </button>
    </form>
</div>