@model Book

<form asp-action="Edit" asp-route-BookID="@Model?.BookID" method="post" class="border border-black p-3 mb-3 col-6">
    <input asp-for="BookID" type="hidden" />
    <div class="form-group">
        <div class="mb-3">
            <label asp-for="Title" class="form-label">@Model?.Title</label>
            <input asp-for="Title" class="form-control" value="@Model?.Title" />
        </div>
    </div>
    <div class="form-group">
        <div class="mb-3 col-3">
            <label asp-for="Genre" class="form-label">@Model?.Genre</label>
            <input asp-for="Genre" class="form-control" />
        </div>
    </div>
    <div class="form-group">
        <div class="mb-3">
            <label asp-for="Description" class="form-label">@Model?.Description</label>
            <input asp-for="Description" class="form-control" />
        </div>
    </div>
    <button class="btn btn-primary">Update</button>
</form>
