@model Book

<form asp-action="DeleteBook" asp-route-BookID="@Model?.BookID" method="post" class="border border-black p-3 mb-3 col-6">
    <input asp-for="BookID" type="hidden" />
    <div class="form-group">
        <div class="mb-3">
            <a asp-for="Title" class="form-label">@Model?.Title</a>
        </div>
    </div>
    <div class="form-group">
        <div class="mb-3 col-3">
            <a asp-for="Genre" class="form-label">@Model?.Genre</a>
        </div>
    </div>
    <div class="form-group">
        <div class="mb-3">
            <a asp-for="Description" class="form-label">@Model?.Description</a>
        </div>
    </div>
    <button class="btn btn-danger">Confirm?</button>
</form>
