@model Book

<form asp-action="DeleteBook" asp-route-BookID="@Model?.BookID" method="post" class="border border-black p-3 mb-3 col-6">
    <input asp-for="BookID" type="hidden" />
    <div class="form-group">
        <div class="mb-3">
            <a asp-for="BookTitle" class="form-label">@Model?.BookTitle</a>
        </div>
    </div>
    <div class="form-group">
        <div class="mb-3 col-3">
            <a asp-for="Genres" class="form-label">@Model?.Genres</a>
        </div>
    </div>
    <div class="form-group">
        <div class="mb-3">
            <a asp-for="BookDescription" class="form-label">@Model?.BookDescription</a>
        </div>
    </div>
    <button class="btn btn-danger">Confirm?</button>
</form>
